generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Request {
  id        Int      @id @default(autoincrement())
  apiType   Int
  createdAt DateTime @default(now())
}

model Account {
  id               Int               @id @default(autoincrement())
  createdAt        DateTime          @default(now())
  isActive         Boolean           @default(true)
  trackId          String            @unique
  type             AccountType
  title            String?
  description      String?
  accountIncomings AccountIncoming[]
}

model AccountIncoming {
  id        Int      @id @default(autoincrement())
  balance   Int
  trackedAt DateTime @default(now())
  accountId Int
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model GameResult {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  gameType  GameType
  name      String
  result    Int
}

model AlphadateBoard {
  id        Int                @id @default(autoincrement())
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  key       String             @unique
  name      String?
  pin       String?
  settings  Json?              @default("{}")
  partners  AlphadatePartner[]
}


model AlphadatePartner {
  id        Int            @id @default(autoincrement())
  boardId   String
  board     AlphadateBoard @relation(fields: [boardId], references: [key], onDelete: Cascade)
  name      String
  turnOrder Int            @db.SmallInt

  @@unique([boardId, turnOrder])
}



enum AccountType {
  mono
  privat
}

enum GameType {
  stroop
}
